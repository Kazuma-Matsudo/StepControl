{
  "manifest_version": 3,
  "name": "StepFlow",
  "version": "1.0.0",
  "description": "ブラウザ操作をワークフローとして自動化するChrome拡張機能",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "clipboardWrite",
    "sidePanel"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
